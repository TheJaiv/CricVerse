# CricVerse — environment variables
# Copy this file to `.env` (which is gitignored) and fill in real values.
# In production these are set as host/Render environment variables, never committed.

# ── Required ──
# Your Discord bot token (Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=your-discord-bot-token-here
# MongoDB connection string (Atlas or self-hosted)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net

# ── Optional ──
# MongoDB database name (default: cricket_bot)
MONGO_DB=cricket_bot
# Channel ID for bot/DB update logs
LOG_CHANNEL_ID=
# Enable the work-in-progress Career Mode (0 = off, 1 = on)
CAREER_MODE=0
# Port for the keep-alive web server (default: 8080)
PORT=8080
