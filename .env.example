# Copy this file to .env (gitignored) and fill in real values.
# In production these are set as host environment variables, never committed.

# Discord bot token (Discord Developer Portal > Bot > Token) - required
DISCORD_TOKEN=your-discord-bot-token-here

# MongoDB connection string (Atlas or self-hosted) - required
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net

# MongoDB database name (default: cricket_bot)
MONGO_DB=cricket_bot

# Discord user ID treated as bot owner/admin
ADMIN_DISCORD_ID=

# Channel ID for bot/DB update logs (optional)
LOG_CHANNEL_ID=

# Enable Career Mode (0 = off, 1 = on)
CAREER_MODE=1

# Port for the keep-alive web server (default: 8080)
PORT=8080
